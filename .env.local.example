# ── Supabase ──────────────────────────────────────────────────────────────────
# Get from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret
NEXTAUTH_URL=http://localhost:3000

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# The price ID for the Pro subscription plan
STRIPE_PRICE_ID=price_...

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@passdropit.com

# ── Facebook OAuth ────────────────────────────────────────────────────────────
# Get from: https://developers.facebook.com/apps
FACEBOOK_CLIENT_ID=your-app-id
FACEBOOK_CLIENT_SECRET=your-app-secret
NEXT_PUBLIC_FACEBOOK_APP_ID=your-app-id

# ── IP Geolocation (IPStack) ──────────────────────────────────────────────────
# Get from: https://ipstack.com
IP_TRACK_KEY=your-ipstack-api-key

# ── Application ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_PASSDROPIT_SITE_URL=https://passdropit.com

# ── Ghost CMS (Blog) ──────────────────────────────────────────────────────────
# Get from your Ghost admin: Settings → Integrations → Add custom integration
NEXT_PUBLIC_GHOST_SITE_URL=https://your-ghost-blog.com
NEXT_PUBLIC_GHOST_API_KEY=your-content-api-key
